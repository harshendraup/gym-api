###############################################
# APPLICATION
###############################################
TZ=UTC
PORT=3333
HOST=0.0.0.0
NODE_ENV=development
APP_KEY=
APP_NAME=GymOS
APP_URL=http://localhost:3333
ADMIN_URL=http://localhost:5173

###############################################
# DATABASE — PostgreSQL
###############################################
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=gymos
DB_PASSWORD=gymos_secret
DB_DATABASE=gymos_dev

###############################################
# REDIS
###############################################
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

###############################################
# JWT
###############################################
JWT_SECRET=<strong-random-secret-min-64-chars>
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

###############################################
# OTP
###############################################
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_MINUTES=15

###############################################
# SMS — MSG91
###############################################
MSG91_API_KEY=
MSG91_SENDER_ID=GYMOS
MSG91_TEMPLATE_ID=

###############################################
# EMAIL — Resend
###############################################
RESEND_API_KEY=
MAIL_FROM_ADDRESS=noreply@gymos.in
MAIL_FROM_NAME=GymOS

###############################################
# STORAGE — S3 / Cloudflare R2
###############################################
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET=gymos-storage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

###############################################
# RAZORPAY
###############################################
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

###############################################
# FIREBASE FCM
###############################################
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

###############################################
# LOGGING
###############################################
LOG_LEVEL=info
SENTRY_DSN=

###############################################
# RATE LIMITING
###############################################
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_AUTH=10