{
  "name": "gymos-api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.6.0"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch bin/server.ts",
    "build": "node --import tsx/esm ace.js build",
    "start": "node bin/server.js",
    "test": "node --import tsx/esm ace.js test",
    "lint": "eslint . --ext=.ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "migration:run": "node --import tsx/esm ace.js migration:run",
    "migration:rollback": "node --import tsx/esm ace.js migration:rollback",
    "migration:fresh": "node --import tsx/esm ace.js migration:fresh --seed",
    "seed": "node --import tsx/esm ace.js db:seed"
  },
  "dependencies": {
    "@adonisjs/auth": "^9.2.3",
    "@adonisjs/bouncer": "^3.1.3",
    "@adonisjs/core": "^6.12.1",
    "@adonisjs/cors": "^2.2.1",
    "@adonisjs/lucid": "^21.2.0",
    "@adonisjs/mail": "^9.2.2",
    "@adonisjs/redis": "^9.1.0",
    "@adonisjs/static": "^1.1.1",
    "@vinejs/vine": "^2.1.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.13.2",
    "firebase-admin": "^12.3.0",
    "luxon": "^3.4.4",
    "nanoid": "^5.0.7",
    "pg": "^8.11.3",
    "pino": "^9.3.2",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.2",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.33.4",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/eslint-config": "^1.3.0",
    "@adonisjs/prettier-config": "^1.3.0",
    "@adonisjs/tsconfig": "^1.3.0",
    "@japa/api-client": "^2.0.3",
    "@japa/assert": "^3.0.0",
    "@japa/runner": "^3.1.2",
    "@swc/core": "^1.7.0",
    "@types/bcrypt": "^6.0.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.9",
    "@types/qrcode": "^1.5.5",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.4"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#models/*": "./app/models/*.js",
    "#services/*": "./app/services/*.js",
    "#helpers/*": "./app/helpers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#validators/*": "./app/validators/*.js",
    "#repositories/*": "./app/repositories/*.js"
  },
  "eslintConfig": {
    "extends": "@adonisjs/eslint-config/app"
  },
  "prettier": "@adonisjs/prettier-config"
}
