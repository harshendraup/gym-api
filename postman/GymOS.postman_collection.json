          "name": "Dashboard Summary",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/gyms/{{GYM_ID}}/analytics/dashboard", "host": ["{{BASE_URL}}"], "path": ["gyms", "{{GYM_ID}}", "analytics", "dashboard"] }
          }
