            "url": { "raw": "{{BASE_URL}}/gyms/{{GYM_ID}}/analytics/attendance?year=2024&month=1", "host": ["{{BASE_URL}}"], "path": ["gyms", "{{GYM_ID}}", "analytics", "attendance"], "query": [{ "key": "year", "value": "2024" }, { "key": "month", "value": "1" }] }
          }
