    {
      "name": "🛡️ Super Admin",
      "item": [
        {
          "name": "List All Gyms",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/admin/gyms?page=1", "host": ["{{BASE_URL}}"], "path": ["admin", "gyms"], "query": [{ "key": "page", "value": "1" }] }
