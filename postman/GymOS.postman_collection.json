              "raw": "{\n  \"gymMemberId\": \"{{MEMBER_ID}}\",\n  \"branchId\": \"{{BRANCH_ID}}\",\n  \"notes\": \"Staff manual check-in\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/gyms/{{GYM_ID}}/attendance/manual", "host": ["{{BASE_URL}}"], "path": ["gyms", "{{GYM_ID}}", "attendance", "manual"] }
          }
        },
        {
          "name": "Today's Attendance",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/gyms/{{GYM_ID}}/attendance/today", "host": ["{{BASE_URL}}"], "path": ["gyms", "{{GYM_ID}}", "attendance", "today"] }
          }
        },
        {
          "name": "Monthly Report",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/gyms/{{GYM_ID}}/attendance/report?year=2024&month=1",
              "host": ["{{BASE_URL}}"],
              "path": ["gyms", "{{GYM_ID}}", "attendance", "report"],
              "query": [{ "key": "year", "value": "2024" }, { "key": "month", "value": "1" }]
            }
          }
        },
        {
          "name": "Get Branch QR Code",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/gyms/{{GYM_ID}}/attendance/qr?branchId={{BRANCH_ID}}", "host": ["{{BASE_URL}}"], "path": ["gyms", "{{GYM_ID}}", "attendance", "qr"], "query": [{ "key": "branchId", "value": "{{BRANCH_ID}}" }] }
          }
        }
      ]
    },
    {
